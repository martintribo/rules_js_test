# pnpm configuration for rules_js testing

# Enable symlinks on Windows
symlink=true

# Required for rules_js - no hoisting
node-linker=isolated

# Peer dependency handling
strict-peer-dependencies=false
auto-install-peers=true

# pnpm 10 build script allowlist (also in package.json pnpm.onlyBuiltDependencies)
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=esbuild
only-built-dependencies[]=lmdb
only-built-dependencies[]=msgpackr-extract
only-built-dependencies[]=nice-napi
