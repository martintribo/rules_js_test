# pnpm configuration for rules_js testing
# Enable symlinks (default on Unix, needs explicit enable on Windows)
symlink=true

# Use hoisted node_modules structure for better Angular compatibility
node-linker=hoisted

# Strict peer dependencies to catch issues
strict-peer-dependencies=false

# Auto-install peers
auto-install-peers=true

# Enable injected workspace packages
# This hardlinks/copies workspace deps instead of symlinking them
# Useful for testing version isolation and bundler compatibility
inject-workspace-packages=true
