# pnpm configuration for rules_js testing
# Enable symlinks (default on Unix, needs explicit enable on Windows)
symlink=true

# Use isolated node_modules to properly test injected vs symlinked workspace packages
# Note: hoisted mode masks injection behavior; isolated mode shows it clearly
node-linker=isolated

# Strict peer dependencies to catch issues
strict-peer-dependencies=false

# Auto-install peers
auto-install-peers=true

# Injected workspace packages - using per-package config instead of global
# This allows testing mixed symlink/inject behavior
# inject-workspace-packages=true
